<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    
    <!-- 自动启停开关 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_start_stop_title"
                android:textSize="18sp"
                android:textStyle="bold" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_start_stop_description"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp" />
            
        </LinearLayout>
        
        <Switch
            android:id="@+id/switchAutoStartStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        
    </LinearLayout>
    
    <!-- 当前选择的设备 -->
    <TextView
        android:id="@+id/tvCurrentDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_current_device"
        android:textSize="14sp"
        android:textColor="#4CAF50"
        android:padding="8dp"
        android:background="#E8F5E9"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />
    
    <!-- 已配对设备列表标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_paired_devices"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />
    
    <!-- 无设备提示 -->
    <TextView
        android:id="@+id/tvNoDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_no_paired_devices"
        android:textSize="14sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />
    
    <!-- 设备列表 -->
    <ListView
        android:id="@+id/listViewDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />
    
    <!-- 清除选择按钮 -->
    <Button
        android:id="@+id/btnClearSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_clear_selection"
        android:backgroundTint="#FF5722"
        android:layout_marginTop="16dp" />
    
</LinearLayout>
